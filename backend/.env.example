# ─────────────────────────────────────────────────────────────
# AI Job Readiness Analyzer — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── AWS Credentials ──────────────────────────────────────────
# Create an IAM user with S3 and Comprehend permissions
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# ── S3 ───────────────────────────────────────────────────────
# The bucket must already exist in your AWS account
S3_BUCKET_NAME=job-readiness-uploads

# ── Decision Thresholds (optional overrides) ─────────────────
APPLY_THRESHOLD=80
IMPROVE_THRESHOLD=50

# ── MongoDB (optional) ───────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=job_readiness
